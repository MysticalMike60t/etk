root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Git Configurations
[{.gitconfig, .gitattributes, .gitignore}]
indent_style = tab
indent_size = 0

[/README.md]
indent_style = space
indent_size = 0

[Makefile]
indent_style = tab
